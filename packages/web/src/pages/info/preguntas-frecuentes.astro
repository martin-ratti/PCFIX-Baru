---
export const prerender = true;

import Layout from "../../layouts/Layout.astro";
import {
    PackageIcon,
    MapPinIcon,
    ClockIcon,
    SearchIcon,
} from "../../components/SharedIcons";

const faqs = [
    {
        question: "¿Hacen envíos a todo el país?",
        answer: "Sí, realizamos envíos a toda Argentina desde nuestra sucursal en Arequito, Santa Fe. Trabajamos con Correo Argentino y otros servicios logísticos como Zipnova. Los pedidos se despachan dentro de las 24/48 horas hábiles posteriores a la acreditación del pago.",
    },
    {
        question: "¿Cuáles son los medios de pago aceptados?",
        answer: "Aceptamos todas las tarjetas de crédito y débito, transferencia bancaria, efectivo en el local y criptomonedas. Pagando por transferencia, efectivo o cripto obtenés un 8% de descuento. También ofrecemos cuotas sin interés con Visa Macro en nuestro local.",
    },
    {
        question: "¿Los productos tienen garantía?",
        answer: "Todos nuestros productos cuentan con garantía oficial del fabricante más nuestro respaldo local. La duración varía según el producto y el fabricante (generalmente 12 meses). Si tenés algún problema, contactanos y te ayudamos con el proceso de garantía.",
    },
    {
        question: "¿Cómo puedo hacer el seguimiento de mi pedido?",
        answer: "Una vez que tu pedido sea despachado, recibirás un email automático con el número de guía o código de seguimiento. Podés seguirlo desde la sección 'Mis Compras' en tu cuenta o directamente en la web del transportista.",
    },
    {
        question: "¿Arman PCs a pedido?",
        answer: "Sí, ofrecemos servicio de armado de PC gamer y workstation a medida. Te asesoramos en la elección de componentes según tus necesidades y presupuesto. Incluye ensamblado, configuración de BIOS, instalación de drivers y testeo de estabilidad.",
    },
    {
        question: "¿Cuánto cuesta el diagnóstico de PC o notebook?",
        answer: "El diagnóstico tiene un costo inicial que funciona como seña. Si decidís reparar con nosotros, ese monto se descuenta del presupuesto final. Consultá los precios actualizados en nuestra sección de Servicio Técnico.",
    },
    {
        question: "¿Puedo retirar mi compra en el local?",
        answer: "Sí, podés optar por retiro en sucursal sin costo adicional de envío. Nuestro local está ubicado en Corrientes 1481, Arequito, Santa Fe. El horario de atención es de Lunes a Viernes de 16 a 20hs y Sábados de 9 a 12hs.",
    },
    {
        question: "¿Cómo puedo contactarlos?",
        answer: "Podés contactarnos por WhatsApp al +54 346 451 3588 (la forma más rápida), por email a pcfixbaru@gmail.com, o visitándonos en nuestro local en Corrientes 1481, Arequito, Santa Fe. También podés enviarnos un mensaje desde la sección de Contacto de la web.",
    },
];

const faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((faq) => ({
        "@type": "Question",
        name: faq.question,
        acceptedAnswer: {
            "@type": "Answer",
            text: faq.answer,
        },
    })),
};
---

<Layout
    title="Preguntas Frecuentes — PCFIX"
    description="Respuestas a las preguntas más comunes sobre envíos, pagos, garantía, servicio técnico y compras en PCFIX. Todo lo que necesitás saber antes de comprar."
>
    <Fragment slot="head">
        <script
            type="application/ld+json"
            set:html={JSON.stringify(faqSchema)}
        />
    </Fragment>

    <main
        class="container mx-auto px-6 py-12 bg-white max-w-4xl shadow-sm my-8 rounded-xl border border-gray-100"
    >
        <h1 class="text-3xl font-black text-secondary mb-2 border-b pb-4">
            Preguntas Frecuentes
        </h1>
        <p class="text-gray-500 mb-10 text-sm">
            Todo lo que necesitás saber sobre compras, envíos, pagos y servicio
            técnico.
        </p>

        <div class="space-y-6">
            {
                faqs.map((faq, index) => (
                    <details
                        class="group bg-gray-50 rounded-xl border border-gray-100 overflow-hidden hover:border-primary/30 transition-colors"
                        open={index === 0}
                    >
                        <summary class="flex items-center justify-between cursor-pointer p-5 text-left font-bold text-secondary hover:text-primary transition-colors select-none">
                            <span class="flex items-center gap-3">
                                <span class="flex-shrink-0 w-8 h-8 bg-primary/10 text-primary rounded-lg flex items-center justify-center text-sm font-black">
                                    {index + 1}
                                </span>
                                {faq.question}
                            </span>
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform duration-200 flex-shrink-0 ml-4"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                stroke-width="2"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M19 9l-7 7-7-7"
                                />
                            </svg>
                        </summary>
                        <div class="px-5 pb-5 pt-0 text-gray-600 leading-relaxed border-t border-gray-100 mt-0">
                            <p class="pt-4">{faq.answer}</p>
                        </div>
                    </details>
                ))
            }
        </div>

        <div
            class="mt-12 p-6 bg-primary/5 rounded-xl border border-primary/10 text-center"
        >
            <p class="text-gray-600 mb-3 font-medium">
                ¿No encontraste lo que buscabas?
            </p>
            <a
                href="/info/contacto"
                class="inline-flex items-center gap-2 px-6 py-2.5 bg-primary text-white font-bold rounded-lg hover:bg-primary/90 transition-colors shadow-sm"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-5 h-5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z"
                    ></path>
                </svg>
                Contactanos
            </a>
        </div>
    </main>
</Layout>
